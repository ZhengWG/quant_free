# QuantFree 后端配置
# 复制为 .env 后按需修改，未填项使用默认或功能降级（如不填 AI 则策略为模拟结果）

# ---------- 服务器 ----------
HOST=0.0.0.0
PORT=3000
DEBUG=True

# ---------- AI（策略推荐、综合智选等）----------
# 不配置则 AI 相关接口返回模拟结果
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4
CLAUDE_API_KEY=

# ---------- 行情数据 ----------
# 默认使用免费新浪/腾讯/东方财富，无需配置。Tushare 为可选备用
TUSHARE_TOKEN=

# ---------- 交易 ----------
# sim=模拟交易（默认），live=实盘（需同时配置 BROKER_API_URL）
TRADING_MODE=sim
# 实盘时指向券商网关地址（如本机 evolving 网关 http://127.0.0.1:7070）
BROKER_API_URL=
# 实盘且 BROKER_API_URL 为 http://127.0.0.1:7070 时，设为 1 则随 main.py 自动启动券商网关（建议实盘时 1）
AUTO_START_BROKER_GATEWAY=0

# ---------- 短信提醒（默认关闭） ----------
# 短信总开关：0=关闭，1=开启
SMS_ENABLED=0
# 短信服务商：webhook / twilio
SMS_PROVIDER=webhook
# 通用接收号码，多个用英文逗号分隔（例：13800138000,13900139000）
SMS_RECEIVERS=
# webhook 模式：POST 到该地址，body={"to","content","event","channel":"sms"}
SMS_WEBHOOK_URL=
# webhook 可选鉴权 token（会放在 Authorization: Bearer <token>）
SMS_WEBHOOK_TOKEN=
# twilio 模式（可选）
SMS_TWILIO_ACCOUNT_SID=
SMS_TWILIO_AUTH_TOKEN=
SMS_TWILIO_FROM=

# ---------- 数据库与日志 ----------
# 以下路径相对 server 目录
DB_PATH=./data/quant_free.db
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
